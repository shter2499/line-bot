# Copy to .env and fill your secrets
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# Use the service name `redis` from docker-compose
REDIS_URL=redis://redis:6379/0
# Optional fallback if REDIS_URL is not set
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0

# Global pause key/ttl settings (default: 24 hours)
# GLOBAL_PAUSE_REDIS_KEY=bot:global:paused
# BOT_GLOBAL_PAUSE_SECONDS=86400

# line_service DB used for fallback status check
# MYSQL_DATABASE_LINE=line_service
# Optionally point to a different Ollama host
# OLLAMA_HOST=http://host.docker.internal:11434
